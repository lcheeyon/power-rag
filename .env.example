# Copy this file to .env and fill in your values before running docker-compose or the backend.
# NEVER commit your actual .env file — it is listed in .gitignore.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
PG_USER=powerrag
PG_PASSWORD=powerrag_secret

# ── LLM API Keys ────────────────────────────────────────────────────────────
# Anthropic Claude  → https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio  → https://aistudio.google.com/app/apikey
# Used for Gemini chat models AND Imagen image generation
GOOGLE_API_KEY=AIza...

# ── JWT signing secret (must be at least 32 characters) ─────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
